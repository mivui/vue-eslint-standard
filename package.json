{
  "name": "vue-eslint-standard",
  "version": "10.1.0",
  "description": "quickly start eslint in vue",
  "type": "module",
  "main": "./dist/index.js",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./*": "./*"
  },
  "scripts": {
    "build": "rollup -c rollup.config.js"
  },
  "dependencies": {
    "eslint-plugin-vue": "^10.8.0",
    "typescript-eslint-standard": "^10.1.0"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-replace": "^6.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/node": "^24.12.0",
    "rollup": "^4.60.0",
    "rollup-plugin-dts": "^6.4.1",
    "tslib": "^2.8.1",
    "vitest": "^4.1.1"
  },
  "author": "mivui",
  "license": "MIT",
  "keywords": [
    "vue",
    "eslint",
    "prettier",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mivui/vue-eslint-standard.git"
  },
  "bugs": {
    "url": "https://github.com/mivui/vue-eslint-standard/issues"
  },
  "homepage": "https://github.com/mivui/vue-eslint-standard#readme"
}
